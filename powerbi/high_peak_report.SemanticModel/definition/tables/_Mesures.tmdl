	measure 'Var CA Label N-1' =
			
			VAR v = [Var CA N-1 %]
			VAR signe =
			    IF ( v >= 0, "↗ +", "↘ " )
			RETURN
			IF (
			    ISBLANK ( v ),
			    "--",
			    signe & FORMAT ( v, "0.0%" ) & " vs N-1"
			)
		displayFolder: CA & Revenus
		lineageTag: 78bb5456-8ea4-454d-807f-8141e4b2d7a7

	measure 'Couleur Var CA' =
			
			VAR v = [Var CA N-1 %]
			RETURN
			SWITCH (
			    TRUE (),
			    ISBLANK ( v ), "#6B7280",
			    v >= 0.05, "#2E7D32",
			    v >= 0, "#7A9A3D",
			    v > -0.05, "#D97706",
			    "#B91C1C"
			)
		displayFolder: CA & Revenus
		lineageTag: b9af5a48-d0f1-4bf9-bb94-d8cb5ca655ec

