	measure 'Var Taux Marge YTD Label' =
			
			VAR v = [Var Taux de Marge YTD]
			RETURN
			IF (
			    ISBLANK ( v ),
			    "--",
			    IF (
			        v >= 0,
			        "↗ +" & FORMAT ( v * 100, "0.0" ) & " pts",
			        "↘ " & FORMAT ( v * 100, "0.0" ) & " pts"
			    )
			)
