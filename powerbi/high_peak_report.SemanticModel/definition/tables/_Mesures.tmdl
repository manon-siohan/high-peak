	measure 'Label Comparaison YTD' =
			
			VAR CurrentMaxDate =
			    MAX ( dim_date[date_jour] )
			VAR CurrentYear =
			    YEAR ( CurrentMaxDate )
			VAR PrevYear =
			    CurrentYear - 1
			VAR EndOfSelectedYear =
			    DATE ( CurrentYear, 12, 31 )
			VAR IsFullYear =
			    CurrentMaxDate = EndOfSelectedYear
			RETURN
			IF (
			    IsFullYear,
			    "vs " & PrevYear,
			    "vs YTD " & PrevYear
			)
		displayFolder: CA & Revenus
		lineageTag: 0c204b03-c80a-4670-97a3-d051143639c4

	measure 'Marge HT YTD N-1' =
			
			CALCULATE (
