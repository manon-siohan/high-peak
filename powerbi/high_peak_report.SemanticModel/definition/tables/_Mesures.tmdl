		formatString: 0
		displayFolder: Clients
		lineageTag: 826fbceb-fadb-4f8c-a630-33cd33168bd4

	measure 'Var Nvx Clients M-1' =
			
			VAR _current = [Nvx Clients]
			VAR _ref = [Nvx Clients M-1]
			VAR _delta = _current - _ref
			VAR _signe = IF(_delta >= 0, "↗ +", "↘ ")
			RETURN
			    IF(
			        ISBLANK(_ref),
			        "--",
			        _signe & _delta & " vs M-1"
			    )
		displayFolder: Clients
		lineageTag: ed5a9bf9-b16e-4212-bfba-65d33ee8cd8a

