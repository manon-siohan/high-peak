	measure 'Clients actifs YTD - Detail' =
			
			VAR var_nb = [Var nb clients actifs YTD]
			VAR var_pct = [Var Clients actifs YTD %]
			VAR label_comp = [Label Comparaison YTD]
			VAR arrow =
			    SWITCH(
			        TRUE(),
			        ISBLANK(var_nb), BLANK(),
			        var_nb > 0, "↗ ",
			        var_nb < 0, "↘ ",
			        "→ "
			    )
			RETURN
			IF(
			    ISBLANK(var_nb) || ISBLANK(var_pct),
			    "--",
			        " clients / "
			        & arrow
			        & FORMAT(var_pct, "+0.0%;-0.0%;0.0%")
			        & " "
			        & label_comp
			)
		displayFolder: Clients
		lineageTag: 6cd69fa6-1382-4b5b-b44e-7eec570bc4ad

	measure 'Titre Courbe CA HT vs N-1' =
			
			VAR annee_selectionnee =
			    SELECTEDVALUE(dim_date[annee])
			VAR annee_n_1 =
			    annee_selectionnee - 1
			RETURN
			IF(
			    ISBLANK(annee_selectionnee),
			    "Évolution mensuelle du CA HT",
			    "Évolution mensuelle du CA HT — "
			        & annee_selectionnee
			        & " vs "
			        & annee_n_1
			)
		displayFolder: CA & Revenus
		lineageTag: 5d7d2584-a158-4392-9bd9-d848757ee540

