	measure 'Nvx Clients' =
			
			CALCULATE(
			    DISTINCTCOUNT(dim_customers[customer_id])
			    , FILTER(
			        dim_customers
			        , dim_customers[date_inscription].[Date] >= MIN(dim_date[date_jour])
			        && dim_customers[date_inscription].[Date] <= MAX(dim_date[date_jour])
			    )
			    )
		formatString: 0
		displayFolder: Clients
		lineageTag: 3264a2cf-ed60-44d5-9335-e00ee27ae5c9

	measure 'Nvx Clients M-1' =
			
			CALCULATE(
			    [Nvx Clients]
			    , DATEADD(dim_date[date_jour], -1, MONTH)
